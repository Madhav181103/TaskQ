# Port number for the Express server to listen on
PORT=8000

# PostgreSQL connection string (Required: application will crash if missing)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskq

# Redis connection URL for the priority queue
REDIS_URL=redis://localhost:6379

# The maximum number of retry attempts for failed jobs before sending them to DLQ
MAX_RETRY_ATTEMPTS=3

# The base time in seconds used to calculate exponential backoff (e.g., delay = BASE ^ attemptNumber seconds)
# Attempt 1: 2^1 = 2s, Attempt 2: 2^2 = 4s, Attempt 3: 2^3 = 8s
RETRY_BACKOFF_BASE_SECONDS=2

# Number of concurrent job handlers running inside the worker process
WORKER_CONCURRENCY=3

# Timeout in seconds before a job stuck in 'processing' is considered timed out and re-queued
PROCESSING_TIMEOUT_SECONDS=30

# URL of the client dashboard to allow CORS requests
CLIENT_URL=http://localhost:5173
